# Testing infrastructure mode:
# - true: start PostgreSQL via Testcontainers
# - false: use DB_* values below
TEST_USE_TESTCONTAINER=true

# Testcontainers PostgreSQL settings (used only when TEST_USE_TESTCONTAINER=true)
TESTCONTAINER_POSTGRES_IMAGE=postgres:16-alpine
TEST_DB_NAME=clinic_registry_test
TEST_DB_USER=clinic_registry_test
TEST_DB_PASSWORD=clinic_registry_test

# Apply Alembic migrations before test session
TEST_RUN_MIGRATIONS=true

# External database settings (used only when TEST_USE_TESTCONTAINER=false)
DB_USER=app
DB_PASSWORD=app
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_DRIVER=postgresql+asyncpg
DB_SYNC_DRIVER=postgresql+psycopg2

JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRATION_MINUTES=80

LOGGING_LVL=DEBUG
LOGGING_FMT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_HEADERS=["*"]
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_CREDENTIALS=true
