{
  "name": "Clinic Registry Backend",
  "dockerComposeFile": "compose.yaml",
  "service": "app",
  "runServices": [
    "app",
    "db"
  ],
  "workspaceFolder": "/workspaces/clinic-registry-backend",
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": false,
      "username": "vscode"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [
    8000,
    5432
  ],
  "portsAttributes": {
    "8000": {
      "label": "API"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "batisteo.vscode-django",
        "ckolkman.vscode-postgres",
        "docker.docker",
        "fastapilabs.fastapi-vscode",
        "github.copilot-chat",
        "github.github-vscode-theme",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "gitlab.gitlab-workflow",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh",
        "ms-vscode-remote.remote-ssh-edit",
        "ms-vscode.remote-explorer",
        "njpwerner.autodocstring",
        "openai.chatgpt",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "rezky.r-dark-pro",
        "wakatime.vscode-wakatime"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports.ruff": "explicit",
          "source.fixAll.ruff": "explicit"
        }
      }
    }
  },
  "onCreateCommand": "uv sync --frozen",
  "postCreateCommand": "uv run pre-commit install",
  "postStartCommand": "uv run alembic upgrade head"
}
